rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Lakes are readable by all authenticated users
    match /lakes/{lakeId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin only

      // Catches: anyone can read, only owner can write
      match /catches/{catchId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.userId == request.auth.uid;
        allow update, delete: if request.auth != null
                              && resource.data.userId == request.auth.uid;
      }

      // Analysis grid: read-only for clients
      match /analysisGrid/{cellId} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      // Depth readings: authenticated users can contribute
      match /depthReadings/{readingId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
      }
    }
  }
}
